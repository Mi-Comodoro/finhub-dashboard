{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git ls-tree:*)",
      "Bash(npm run lint:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(npx nuxi typecheck:*)",
      "Bash(node --version:*)",
      "Bash(npm --version:*)",
      "Bash(timeout 30 npm run dev:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Bash(powershell:*)",
      "Bash(taskkill:*)",
      "Bash(rm -rf /:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
